# Пример переменных окружения. РЕАЛЬНЫЕ значения — только в серверном .env,
# в git НЕ коммитятся (репозиторий публичный). Скопировать в .env и заполнить.

# --- Приложение ---
APP_ENV=local                 # local | staging | production

# --- База данных / кеш ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/vk_ads_auto
REDIS_URL=redis://HOST:6379/0

# Используются сервисом postgres в docker-compose:
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=vk_ads_auto

# --- Telegram-бот ---
BOT_TOKEN=                    # токен @BotFather
OPERATOR_TELEGRAM_IDS=        # Telegram ID операторов через запятую (доступ только им)

# --- VK Ads API (VK Реклама) — OAuth2-токен ---
VK_ADS_ACCESS_TOKEN=          # Bearer access_token
VK_ADS_REFRESH_TOKEN=         # refresh_token (обновление access_token)
VK_ADS_TOKEN_TYPE=Bearer

# --- Google (Forms / Sheets, сервис-аккаунт) ---
GOOGLE_SERVICE_ACCOUNT_JSON=  # путь к JSON сервис-аккаунта
GOOGLE_SHEET_ID=

# --- Senler ---
SENLER_API_KEY=

# --- n8n (см. docs/N8N.md) ---
N8N_API_URL=
N8N_API_KEY=
N8N_ENCRYPTION_KEY=

# --- Userbot (Telethon-сервис доставки в Telegram, spec 2026-07-13) ---
USERBOT_BASE_URL=http://userbot:8001   # внутри compose-сети (клиент ядра)
USERBOT_SECRET_KEY=                    # Fernet-ключ (base64, 32 байта) для шифрования сессий операторов
USERBOT_API_ID=                        # api_id приложения с my.telegram.org
USERBOT_API_HASH=                      # api_hash приложения с my.telegram.org
USERBOT_SESSIONS_DIR=/secrets          # каталог сессий операторов: {sender_id}.session.enc (persistent volume)

# --- SMTP (Beget): info@ — информационные (ссылка на бриф), support@ — технические (кабинет) ---
SMTP_HOST=smtp.beget.com                # общий SMTP-сервер (Beget)
SMTP_PORT=465                           # SSL (альтернатива 2525, если 25/465 заблокирован)
SMTP_INFO_USER=info@vk-ads-auto.ru      # отправитель информационных писем
SMTP_INFO_PASSWORD=                      # пароль ящика info@
SMTP_INFO_FROM_NAME=VK Ads Auto
SMTP_SUPPORT_USER=support@vk-ads-auto.ru # отправитель технических писем (кабинет)
SMTP_SUPPORT_PASSWORD=                    # пароль ящика support@
SMTP_SUPPORT_FROM_NAME=VK Ads Auto
